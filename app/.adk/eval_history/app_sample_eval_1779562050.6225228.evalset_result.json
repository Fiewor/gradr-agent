uments'][0]\\n    max_score_attainable = exam_info.get('maxScoreAttainable')\\n    exam_type = exam_info.get('examType', \\\"WAEC\\\")\\n    exam_questions_from_doc = exam_info.get('questions')\\n\\nif max_score_attainable is None and marking_guide_category_id:\\n    category_doc = default_api.find(\\n        database='test',\\n        collection='categories',\\n        filter={'_id': marking_guide_category_id},\\n        limit=1\\n    )\\n    if category_doc and category_doc.get('documents'):\\n        max_score_attainable = category_doc['documents'][0].get('maxScoreAttainable')\\n\\nif max_score_attainable is None:\\n    max_score_attainable = 100 # Default if nothing found, for pipeline robustness\\n\\n# 4. Fetch full guide text\\nguide_text = \\\"\\\"\\nif file_url:\\n    try:\\n        gcs_resource_content = default_api.get_resource_from_gcs(bucket_uri=file_url)\\n        guide_text = gcs_resource_content.get('text', '')\\n        if not guide_text:\\n            raise ValueError(\\\"GCS resource returned no text.\\\")\\n    except Exception as e:\\n        guide_text = \\\"Minimal dummy rubric text for fallback.\\\"\\nelse:\\n    guide_text = \\\"Minimal dummy rubric text for fallback.\\\"\\n\\n# 5. Produce structured rubric\\nrubric_result = None\\nif guide_text == \\\"Minimal dummy rubric text for fallback.\\\":\\n    rubric_result = {\\n        \\\"rubric\\\": {\\n            \\\"rubric_items\\\": [\\n                {\\\"criterion\\\": \\\"General understanding\\\", \\\"max_score\\\": max_score_attainable}\\n            ],\\n            \\\"max_score\\\": max_score_attainable\\n        }\\n    }\\nelse:\\n    rubric_result = default_api.parse_marking_guide(\\n        text=guide_text,\\n        max_score=max_score_attainable\\n    )\\nrubric = rubric_result['rubric']\\n\\n# 6. Retrieve historical performance\\nhistorical_performance_raw = default_api.find(\\n    database='test',\\n    collection='results',\\n    filter={'studentId': student_id},\\n    limit=5,\\n    sort={'createdAt': -1}\\n)\\nhistorical_performance = []\\nif historical_performance_raw and historical_performance_raw.get('documents'):\\n    for doc in historical_performance_raw['documents']:\\n        performance_entry = {\\n            \\\"score\\\": doc.get('score'),\\n            \\\"feedback\\\": doc.get('feedback'),\\n            \\\"createdAt\\\": doc.get('createdAt')\\n        }\\n        historical_performance.append(performance_entry)\\n\\n# 7. OCR the student script\\nocr_text = None\\ntry:\\n    ocr_result = default_api.extract_handwritten_text(bucket_uri=script_gcs_uri)\\n    ocr_text = ocr_result.get('text')\\n    if not ocr_text:\\n        raise ValueError(\\\"OCR returned no text.\\\")\\nexcept Exception as e:\\n    ocr_text = None\\n\\n# 8. Split into question-answer pairs\\nquestions_for_output = []\\n\\nif ocr_text is None:\\n    questions_for_output = [\\n        {\\\"question_id\\\": \\\"q1\\\", \\\"question\\\": \\\"Explain AI\\\", \\\"student_answer\\\": \\\"Mock answer due to unreadable script\\\"}\\n    ]\\nelse:\\n    exam_questions = []\\n\\n    if exam_questions_from_doc:\\n        for q_item in exam_questions_from_doc:\\n            exam_questions.append({\\n                \\\"question_id\\\": q_item.get('_id', f\\\"q_{len(exam_questions)+1}\\\"),\\n                \\\"question\\\": q_item.get('questionText', '')\\n            })\\n\\n    if not exam_questions:\\n        questions_resource_raw = default_api.find(\\n            database='test',\\n            collection='resources',\\n            filter={'type': 'questions', 'examId': exam_id},\\n            limit=1\\n        )\\n        if questions_resource_raw and questions_resource_raw.get('documents'):\\n            questions_resource_doc = questions_resource_raw['documents'][0]\\n            questions_file_url = questions_resource_doc.get('fileUrl')\\n            if questions_file_url:\\n                try:\\n                    questions_text_raw = default_api.get_resource_from_gcs(bucket_uri=questions_file_url)\\n                    questions_text = questions_text_raw.get('text', '')\\n                    if questions_text:\\n                        parsed_questions_result = default_api.parse_questions(text=questions_text)\\n                        if parsed_questions_result and parsed_questions_result.get('questions'):\\n                            for q_item in parsed_questions_result['questions']:\\n                                exam_questions.append({\\n                                    \\\"question_id\\\": q_item.get('id', f\\\"q_{len(exam_questions)+1}\\\"),\\n                                    \\\"question\\\": q_item.get('questionText', '')\\n                                })\\n                except Exception as e:\\n                    exam_questions = [] # Reset to trigger dummy fallback\\n\\n    if not exam_questions:\\n        questions_for_output = [\\n            {\\\"question_id\\\": \\\"q1\\\", \\\"question\\\": \\\"Answer all questions based on the provided script.\\\", \\\"student_answer\\\": ocr_text}\\n        ]\\n    else:\\n        for q in exam_questions:\\n            questions_for_output.append({\\n                \\\"question_id\\\": q['question_id'],\\n                \\\"question\\\": q['question'],\\n                \\\"student_answer\\\": ocr_text\\n            })\\n\\n# Construct final output JSON\\noutput = {\\n    \\\"linked_user_id\\\": linked_user_id,\\n    \\\"max_score\\\": max_score_attainable,\\n    \\\"exam_type\\\": exam_type,\\n    \\\"rubric\\\": rubric,\\n    \\\"historical_performance\\\": historical_performance,\\n    \\\"questions\\\": questions_for_output\\n}\\nprint(json.dumps(output, indent=2))\",\"interrupted\":null,\"custom_metadata\":{\"__llm_request_key__\":\"e2a50f2d-60a6-41af-b9d6-a9b105bb6ab4\"},\"usage_metadata\":{\"cache_tokens_details\":null,\"cached_content_token_count\":null,\"candidates_token_count\":null,\"candidates_tokens_details\":null,\"prompt_token_cou